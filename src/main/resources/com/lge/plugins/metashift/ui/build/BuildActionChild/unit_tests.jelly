<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:st="jelly:stapler" xmlns:d="jelly:define"
xmlns:l="/lib/layout" xmlns:t="/lib/hudson" xmlns:f="/lib/form" xmlns:ms="/metashift"
xmlns:dt="/data-tables">
  <l:layout title="meta-shift report">
    <st:include it="${it.run}" page="sidepanel.jelly" />
    <l:main-panel>
      <div class="metashift">
        <div class="page">
          <div class="h1">Overview</div>
          <ms:metrics-stats-header
            statistics_class="percent"
            labels='[
              {"name":"Passed", "clazz": "valid-good"},
              {"name":"Failed", "clazz": "valid-bad"},
              {"name":"Error", "clazz": "valid-error"},
              {"name":"Skipped", "clazz": "invalid"}
            ]' />
          <div class="h1">Details</div>
          <div class="section">
            <dt:table model="${it.getTableModel('unit_tests')}" />
          </div>
        </div>
      </div>
    </l:main-panel>
  </l:layout>
</j:jelly>
